# Copy to .env and fill real values. .env is git-ignored — NEVER commit secrets.
# Athenaeum consumes the shared Azure envs; it has no coupling to backend/frontend.

# --- Microsoft Foundry project (for wiring the KB into a Foundry agent, optional) ---
FOUNDRY_PROJECT_ENDPOINT=https://<resource>.services.ai.azure.com/api/projects/<project>

# --- Azure OpenAI (used by the AI Search vectorizer to embed documents) ---
AZURE_OPENAI_ENDPOINT=https://<resource>.openai.azure.com/
AZURE_OPENAI_API_KEY=<key>                       # used by the search vectorizer; prefer MI in prod
AZURE_OPENAI_API_VERSION=2024-10-21
EMBED_DEPLOYMENT=text-embedding-3-large
EMBED_MODEL=text-embedding-3-large
EMBED_DIMENSIONS=3072
GPT_DEPLOYMENT=gpt-4o-mini                        # KB answer-synthesis model

# --- Azure AI Search (Foundry IQ KnowledgeBase host) — filled after `athenaeum provision` ---
SEARCH_ENDPOINT=https://<search-service>.search.windows.net
SEARCH_ADMIN_KEY=<admin-key>                      # prefer DefaultAzureCredential; key is build-time fallback
SEARCH_API_VERSION=2025-08-01-preview

# --- Resource provisioning targets (used by scripts/provision.sh) ---
AZURE_LOCATION=eastus2
SEARCH_RESOURCE_GROUP=rg-athenaeum
SEARCH_SERVICE_NAME=athenaeum-search
SEARCH_SKU=basic
AOAI_ACCOUNT_NAME=ajayaditya-msf-resource
AOAI_RESOURCE_GROUP=NetworkWatcherRG

# --- Athenaeum index/KB names ---
INDEX_NAME=athenaeum-courses
KNOWLEDGE_SOURCE_NAME=athenaeum-course-source
KNOWLEDGE_BASE_NAME=athenaeum-knowledge-base
