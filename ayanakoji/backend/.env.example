# Copy to .env and fill real values. .env is git-ignored — NEVER commit secrets.

# --- App ---
APP_NAME=athenaeum-backend
ENVIRONMENT=development
CORS_ORIGINS=http://localhost:3000

# --- Learner workspace (courses / messages / assessments) ---
# SQLite by default (file relative to the backend working directory).
# DATABASE_URL=sqlite:///./athenaeum.db
# Force deterministic offline chat replies (no Azure calls). CI/E2E set this true.
# OFFLINE_LLM=false
# Athenaeum course catalog path; defaults to ../../athenaeum/content/_catalog.json
# ATHENAEUM_CATALOG_PATH=

# --- Assessment question banks (SEPARATE DB from the learner workspace) ---
# Authored per-module question banks; their own SQLite file by default.
# ASSESSMENTS_DATABASE_URL=sqlite:///./assessments.db
# Azure Blob mirror for the banks (credential-gated; auth = DefaultAzureCredential).
# AZURE_STORAGE_ACCOUNT=<your-storage-account-name>
# ASSESSMENT_BLOB_CONTAINER=assessment-banks

# --- Microsoft Foundry / Azure OpenAI (filled in the Foundry setup step) ---
# FOUNDRY_PROJECT_ENDPOINT=https://<resource>.services.ai.azure.com/api/projects/<project>
# AZURE_OPENAI_ENDPOINT=https://<resource>.openai.azure.com/
# AZURE_OPENAI_API_KEY=<your-key>           # prefer DefaultAzureCredential in prod
# AZURE_OPENAI_API_VERSION=2024-10-21
# MODEL_WORKHORSE=gpt-4o-mini
# MODEL_REASONING=o4-mini
# MODEL_EMBED=text-embedding-3-large
# MODEL_FAST=gpt-4o-mini                    # cheap classifier for router/injection-gate (e.g. a Phi deployment)

# --- Groq fallback (3rd/4th tier of the model fallback chain; 1st/2nd are Azure) ---
# GROQ_API_KEY=<your-groq-key>              # rotate-on-exposure; .env is git-ignored
# GROQ_BASE_URL=https://api.groq.com/openai/v1
# GROQ_MODEL_WORKHORSE=llama-3.3-70b-versatile
# GROQ_MODEL_FAST=llama-3.1-8b-instant
# GROQ_MODEL_REASONING=deepseek-r1-distill-llama-70b
# GROQ_MODEL_GUARD=meta-llama/llama-prompt-guard-2-86m   # purpose-built injection/jailbreak classifier
# GUARD_BLOCK_THRESHOLD=0.8                               # block when jailbreak probability ≥ this

# --- Athenaeum Foundry IQ knowledge base (knowledge_base_retrieve MCP endpoint) ---
KNOWLEDGE_BASE_MCP_ENDPOINT=https://athenaeum-search-759d4908.search.windows.net/knowledgebases/athenaeum-knowledge-base/mcp?api-version=2025-08-01-preview
