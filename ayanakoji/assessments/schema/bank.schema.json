{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://athenaeum.local/schemas/assessment-bank.json",
  "title": "Module Assessment Bank",
  "description": "Authored question bank for one Athenaeum catalog module: a 5-question choices test (MCQ/MSQ) and a 3-question LLM (explanation) test. Grounded purely on the module's content.",
  "type": "object",
  "additionalProperties": false,
  "required": ["course_id", "module_id", "module_title", "choices", "llm"],
  "properties": {
    "course_id": {
      "type": "string",
      "pattern": "^[a-z]{2}-c[0-9]{2}$",
      "description": "Catalog course id, e.g. 'cb-c01'."
    },
    "module_id": {
      "type": "string",
      "pattern": "^[a-z]{2}-c[0-9]{2}-m[0-9]{2}$",
      "description": "Catalog module id, e.g. 'cb-c01-m01'."
    },
    "module_title": {
      "type": "string",
      "minLength": 1
    },
    "choices": {
      "type": "array",
      "description": "Exactly 5 multiple-choice / multiple-select questions.",
      "minItems": 5,
      "maxItems": 5,
      "items": { "$ref": "#/$defs/choiceQuestion" }
    },
    "llm": {
      "type": "array",
      "description": "Exactly 3 open-ended explanation questions with reference answers.",
      "minItems": 3,
      "maxItems": 3,
      "items": { "$ref": "#/$defs/llmQuestion" }
    }
  },
  "$defs": {
    "choiceQuestion": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "module_id", "prompt", "kind", "choices", "correct_answers"],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^[a-z]{2}-c[0-9]{2}-m[0-9]{2}-c0[1-5]$",
          "description": "Stable id: '<module_id>-c<NN>', NN in 01..05."
        },
        "module_id": {
          "type": "string",
          "pattern": "^[a-z]{2}-c[0-9]{2}-m[0-9]{2}$"
        },
        "prompt": { "type": "string", "minLength": 1 },
        "kind": {
          "type": "string",
          "enum": ["mcq", "msq"],
          "description": "mcq = exactly one correct; msq = two or more correct."
        },
        "choices": {
          "type": "array",
          "description": "Exactly 4 distinct answer options.",
          "minItems": 4,
          "maxItems": 4,
          "uniqueItems": true,
          "items": { "type": "string", "minLength": 1 }
        },
        "correct_answers": {
          "type": "array",
          "description": "Subset of choices that are correct. Each must appear verbatim in choices. Cross-checked against kind by the validator.",
          "minItems": 1,
          "maxItems": 4,
          "uniqueItems": true,
          "items": { "type": "string", "minLength": 1 }
        }
      }
    },
    "llmQuestion": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "module_id", "prompt", "reference_answer"],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^[a-z]{2}-c[0-9]{2}-m[0-9]{2}-l0[1-3]$",
          "description": "Stable id: '<module_id>-l<NN>', NN in 01..03."
        },
        "module_id": {
          "type": "string",
          "pattern": "^[a-z]{2}-c[0-9]{2}-m[0-9]{2}$"
        },
        "prompt": { "type": "string", "minLength": 1 },
        "reference_answer": {
          "type": "string",
          "minLength": 1,
          "description": "Complete, correct model answer a grader scores the learner against."
        }
      }
    }
  }
}
